<UserControl x:Class="JewelryBillingSoft.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold" Foreground="#1A1A2E"/>
                <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='Today: {0:dddd, MMMM dd, yyyy}'}"
                           FontSize="13" Foreground="#888888"
                           xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
            </StackPanel>

            <!-- Stats Grid -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Today's Sales -->
                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="42" Height="42" CornerRadius="10" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#B8860B" Offset="0"/>
                                        <GradientStop Color="#FFD700" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="💰" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Today's Sales" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="{Binding TodaysSales, StringFormat='₹{0:N0}'}"
                                           FontSize="22" FontWeight="Bold" Foreground="#1A1A2E"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding TodaysInvoices, StringFormat='{}{0} Invoices'}"
                                   Foreground="#888888" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Monthly Sales -->
                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="42" Height="42" CornerRadius="10" Background="#E3F2FD" Margin="0,0,12,0">
                                <TextBlock Text="📅" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Monthly Sales" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="{Binding MonthlySales, StringFormat='₹{0:N0}'}"
                                           FontSize="22" FontWeight="Bold" Foreground="#1A1A2E"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="This month" Foreground="#888888" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Customers -->
                <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="42" Height="42" CornerRadius="10" Background="#E8F5E9" Margin="0,0,12,0">
                                <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Total Customers" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="{Binding TotalCustomers}" FontSize="22" FontWeight="Bold" Foreground="#1A1A2E"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Registered customers" Foreground="#888888" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Pending Amount -->
                <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Width="42" Height="42" CornerRadius="10" Background="#FFF3E0" Margin="0,0,12,0">
                                <TextBlock Text="⏳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Pending Amount" Foreground="#888888" FontSize="12"/>
                                <TextBlock Text="{Binding PendingAmount, StringFormat='₹{0:N0}'}"
                                           FontSize="22" FontWeight="Bold" Foreground="#E94560"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Unpaid balances" Foreground="#888888" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Second row stats -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="📦 Total Products" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TotalProducts}" FontSize="28" FontWeight="Bold" Foreground="#B8860B"/>
                        <TextBlock Text="{Binding LowStockItems, StringFormat='{}{0} items low on stock'}"
                                   Foreground="#FF9800" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="⚠️ Low Stock Alert" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding LowStockItems}" FontSize="28" FontWeight="Bold" Foreground="#E94560"/>
                        <TextBlock Text="Items need restocking" Foreground="#888888" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Recent Invoices -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="8">
                <StackPanel>
                    <TextBlock Text="Recent Invoices" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                    <DataGrid ItemsSource="{Binding RecentInvoices}" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True" MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="120"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="100"/>
                            <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat='₹{0:N0}'}" Width="100"/>
                            <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat='₹{0:N0}'}" Width="100"/>
                            <DataGridTextColumn Header="Pending" Binding="{Binding PendingAmount, StringFormat='₹{0:N0}'}" Width="100"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusName}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>

