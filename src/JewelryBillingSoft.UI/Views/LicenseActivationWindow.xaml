<Window x:Class="JewelryBillingSoft.UI.Views.LicenseActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="License Activation - Jewelry Billing Soft"
        Height="600" Width="520"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="35,25,35,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">
                <TextBlock Text="💎" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="Activate Your License" FontSize="22" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <TextBlock Text="Enter your license key to activate Jewelry Billing Soft"
                           Foreground="#888888" FontSize="13" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="1">
                <!-- Expired notice -->
                <Border Background="#FFF3CD" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                        Visibility="{Binding LicenseStatus, Converter={StaticResource NullToInverseVisibilityConverter}}">
                    <TextBlock Text="Your license has expired. Please renew." Foreground="#856404"/>
                </Border>

                <!-- Activation Message -->
                <Border Background="#D4EDDA" CornerRadius="8" Padding="12" Margin="0,0,0,15"
                        Visibility="{Binding ActivationMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ActivationMessage}" Foreground="#155724"/>
                </Border>

                <!-- Shop Name -->
                <TextBlock Text="Shop Name *" FontSize="12" Foreground="#444444" FontWeight="SemiBold"/>
                <TextBox Text="{Binding ShopName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,15" Padding="12,10" FontSize="14"/>

                <!-- Email -->
                <TextBlock Text="Email" FontSize="12" Foreground="#444444" FontWeight="SemiBold"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,15" Padding="12,10" FontSize="14"/>

                <!-- License Key -->
                <TextBlock Text="License Key *" FontSize="12" Foreground="#444444" FontWeight="SemiBold"/>
                <TextBox Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,5,0,4" Padding="12,10"
                         FontFamily="Consolas" FontSize="14"/>
                <TextBlock Text="Format: XXXX-XXXX-XXXX-XXXX  (e.g. DEMO-DEMO-DEMO-DEMO1)"
                           Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,20"/>

                <!-- Activate Button -->
                <Button Content="🔑  Activate License"
                        Command="{Binding ActivateCommand}"
                        Height="48" FontSize="15" FontWeight="Bold"
                        HorizontalAlignment="Stretch"
                        Cursor="Hand" BorderThickness="0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#B8860B" Offset="0"/>
                            <GradientStop Color="#DAA520" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Foreground>
                        <SolidColorBrush Color="White"/>
                    </Button.Foreground>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Footer -->
            <TextBlock Grid.Row="2"
                       Text="Contact support@jewelrysoft.com for license key"
                       Foreground="#AAAAAA" FontSize="11"
                       HorizontalAlignment="Center" Margin="0,18,0,0"/>
        </Grid>
    </ScrollViewer>
</Window>
