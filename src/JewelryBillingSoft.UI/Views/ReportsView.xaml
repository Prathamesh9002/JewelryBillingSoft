<UserControl x:Class="JewelryBillingSoft.UI.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Reports &amp; Analytics" FontSize="26" FontWeight="Bold"
                   Foreground="#1A1A2E" Margin="0,0,0,20"/>

        <!-- Report Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Generate Report" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Report Type:" VerticalAlignment="Center" Margin="0,0,10,0" Width="90"/>
                    <ComboBox ItemsSource="{Binding ReportTypes}" SelectedItem="{Binding SelectedReportType}"
                              Width="180" Margin="0,0,20,0"/>
                    <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding ReportFromDate}" Width="130" Margin="0,0,15,0"/>
                    <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding ReportToDate}" Width="130" Margin="0,0,15,0"/>
                    <Button Content="📊 Generate" Command="{Binding GenerateReportCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Report Content -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <StackPanel>
                <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,10"
                             Foreground="#B8860B" Background="Transparent"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <TextBlock Text="Select a report type and click Generate to view results."
                           Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Center"
                           Margin="0,50,0,0"
                           Visibility="{Binding ReportData, Converter={StaticResource NullToVisibilityConverter}}"/>

                <!-- Report data is displayed dynamically via ContentPresenter -->
                <ContentPresenter Content="{Binding ReportData}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

