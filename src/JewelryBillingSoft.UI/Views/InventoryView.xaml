<UserControl x:Class="JewelryBillingSoft.UI.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Inventory Management" FontSize="26" FontWeight="Bold" Foreground="#1A1A2E"/>
            <Button Grid.Column="1" Content="+ Add Product" Command="{Binding AddNewCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </Grid>

        <!-- Summary Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total Items" Foreground="#888888" FontSize="11"/>
                    <TextBlock Text="{Binding StockSummary.TotalItems}" FontSize="20" FontWeight="Bold" Foreground="#B8860B"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="15">
                <StackPanel>
                    <TextBlock Text="Gold Items" Foreground="#888888" FontSize="11"/>
                    <TextBlock Text="{Binding StockSummary.GoldItems}" FontSize="20" FontWeight="Bold" Foreground="#FFD700"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="15">
                <StackPanel>
                    <TextBlock Text="Diamond Items" Foreground="#888888" FontSize="11"/>
                    <TextBlock Text="{Binding StockSummary.DiamondItems}" FontSize="20" FontWeight="Bold" Foreground="#4CAF50"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource CardStyle}" Padding="15">
                <StackPanel>
                    <TextBlock Text="Total Value" Foreground="#888888" FontSize="11"/>
                    <TextBlock Text="{Binding StockSummary.TotalValue, StringFormat='₹{0:N0}'}" FontSize="20" FontWeight="Bold" Foreground="#2196F3"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Filters -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                         Width="300" Margin="0,0,10,0"
                         materialDesign:HintAssist.Hint="Search products..."
                         xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"/>
                <ComboBox ItemsSource="{Binding MetalTypes}"
                          SelectedItem="{Binding FilterMetalType}"
                          Width="120" Margin="0,0,10,0"/>
                <Button Content="🔍 Search" Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <!-- Product Grid -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding ItemCode}" Width="80"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="100"/>
                            <DataGridTextColumn Header="Metal" Binding="{Binding MetalTypeName}" Width="70"/>
                            <DataGridTextColumn Header="Net Wt" Binding="{Binding NetWeight, StringFormat='{}{0:F2}g'}" Width="75"/>
                            <DataGridTextColumn Header="Rate" Binding="{Binding SellingPrice, StringFormat='₹{0:N0}'}" Width="90"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="65"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StockStatus}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="✏️ Edit" Command="{Binding EditSelectedCommand}"
                                Background="#2196F3" Foreground="White" BorderThickness="0"
                                Padding="15,8" Cursor="Hand" Margin="0,0,10,0"/>
                        <Button Content="🗑️ Delete" Command="{Binding DeleteSelectedCommand}"
                                Background="#F44336" Foreground="White" BorderThickness="0"
                                Padding="15,8" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Edit Panel -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Product Details" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                        <TextBlock Text="Name *" FontSize="12" Foreground="#666666"/>
                        <TextBox Text="{Binding EditingProduct.Name}" Margin="0,4,0,10"/>

                        <TextBlock Text="Metal Type" FontSize="12" Foreground="#666666"/>
                        <ComboBox SelectedItem="{Binding EditingProduct.MetalType}"
                                  Margin="0,4,0,10">
                            <ComboBoxItem Content="Gold"/>
                            <ComboBoxItem Content="Silver"/>
                            <ComboBoxItem Content="Diamond"/>
                        </ComboBox>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Gross Weight (g)" FontSize="12" Foreground="#666666"/>
                                <TextBox Text="{Binding EditingProduct.GrossWeight}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Net Weight (g)" FontSize="12" Foreground="#666666"/>
                                <TextBox Text="{Binding EditingProduct.NetWeight}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Selling Price (₹)" FontSize="12" Foreground="#666666"/>
                                <TextBox Text="{Binding EditingProduct.SellingPrice}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Making Charges" FontSize="12" Foreground="#666666"/>
                                <TextBox Text="{Binding EditingProduct.MakingCharges}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Wastage %" FontSize="12" Foreground="#666666"/>
                                <TextBox Text="{Binding EditingProduct.WastagePercentage}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="GST %" FontSize="12" Foreground="#666666"/>
                                <TextBox Text="{Binding EditingProduct.GSTPercentage}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Stock Quantity" FontSize="12" Foreground="#666666"/>
                        <TextBox Text="{Binding EditingProduct.StockQuantity}" Margin="0,4,0,10"/>

                        <TextBlock Text="HSN Code" FontSize="12" Foreground="#666666"/>
                        <TextBox Text="{Binding EditingProduct.HSNCode}" Margin="0,4,0,20"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Save" Command="{Binding SaveCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                            <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                    Background="#EEEEEE" BorderThickness="0" Padding="15,10" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

