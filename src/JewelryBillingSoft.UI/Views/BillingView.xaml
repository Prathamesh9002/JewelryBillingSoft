<UserControl x:Class="JewelryBillingSoft.UI.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Billing &amp; Invoices" FontSize="26" FontWeight="Bold" Foreground="#1A1A2E" VerticalAlignment="Center"/>
            <DatePicker Grid.Column="1" SelectedDate="{Binding FromDate}" Margin="0,0,10,0" Width="130"/>
            <DatePicker Grid.Column="2" SelectedDate="{Binding ToDate}" Margin="0,0,10,0" Width="130"/>
            <Button Grid.Column="3" Content="🔍 Filter" Command="{Binding LoadCommand}"
                    Background="#EEEEEE" BorderThickness="0" Padding="12,8" Cursor="Hand" Margin="0,0,10,0"/>
            <Button Grid.Column="4" Content="+ New Invoice" Command="{Binding NewInvoiceCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="500"/>
            </Grid.ColumnDefinitions>

            <!-- Invoice List -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Invoices" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Invoices}"
                              IsReadOnly="True"
                              MouseDoubleClick="InvoicesGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" Width="100"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat='{}{0:dd/MM/yy}'}" Width="85"/>
                            <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat='₹{0:N0}'}" Width="90"/>
                            <DataGridTextColumn Header="Paid" Binding="{Binding PaidAmount, StringFormat='₹{0:N0}'}" Width="90"/>
                            <DataGridTextColumn Header="Balance" Binding="{Binding PendingAmount, StringFormat='₹{0:N0}'}" Width="90"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding StatusName}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Right Panel: New Invoice or Invoice Details -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <!-- New Invoice Form -->
                    <StackPanel Visibility="{Binding IsCreatingInvoice, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="New Invoice" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!-- Customer Selection -->
                        <TextBlock Text="Customer *" FontSize="12" Foreground="#666666"/>
                        <ComboBox ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}"
                                  DisplayMemberPath="Name"
                                  Margin="0,4,0,15"/>

                        <!-- Product Selection -->
                        <TextBlock Text="Add Item" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ComboBox ItemsSource="{Binding Products}"
                                  SelectedItem="{Binding SelectedProduct}"
                                  DisplayMemberPath="Name"
                                  Margin="0,4,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Qty" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding ItemQuantity}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="Net Wt (g)" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding ItemNetWeight}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBlock Text="Rate/g (₹)" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding ItemRatePerGram}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                <TextBlock Text="Making (₹)" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding ItemMakingCharges}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="Wastage %" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding ItemWastagePercentage}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="4,0,0,0">
                                <TextBlock Text="Discount %" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding ItemDiscountPercentage}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="+ Add Item" Command="{Binding AddItemToInvoiceCommand}"
                                Background="#4CAF50" Foreground="White" BorderThickness="0"
                                Padding="15,8" Cursor="Hand" Margin="0,0,0,15" HorizontalAlignment="Left"/>

                        <!-- Items List -->
                        <TextBlock Text="Invoice Items" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DataGrid ItemsSource="{Binding CurrentItems}" IsReadOnly="True"
                                  MaxHeight="150" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item" Binding="{Binding ItemDescription}" Width="*"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="40"/>
                                <DataGridTextColumn Header="Wt" Binding="{Binding NetWeight, StringFormat='{}{0:F2}'}" Width="55"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat='₹{0:N0}'}" Width="80"/>
                                <DataGridTemplateColumn Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Background="Transparent" BorderThickness="0"
                                                    Foreground="Red" Cursor="Hand" FontSize="12"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Totals -->
                        <Border Background="#F8F9FA" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Grand Total:" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{Binding CalculatedTotal, StringFormat='₹{0:N2}'}"
                                               FontWeight="Bold" FontSize="16" Foreground="#B8860B"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Payment -->
                        <TextBlock Text="Payment" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="Cash (₹)" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding CashAmount}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Card (₹)" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding CardAmount}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="UPI (₹)" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding UpiAmount}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="UPI Reference" FontSize="11" Foreground="#666666"/>
                                <TextBox Text="{Binding UpiReference}" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="✅ Save &amp; Print" Command="{Binding FinalizeInvoiceCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0"/>
                            <Button Content="Cancel" Command="{Binding CancelInvoiceCommand}"
                                    Background="#EEEEEE" BorderThickness="0" Padding="15,10" Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Invoice Details (view mode) -->
                    <StackPanel Visibility="{Binding IsCreatingInvoice, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <StackPanel Visibility="{Binding CurrentInvoice, Converter={StaticResource NullToVisibilityConverter}}">
                            <Grid Margin="0,0,0,15">
                                <TextBlock Text="{Binding CurrentInvoice.InvoiceNumber, StringFormat='Invoice: {0}'}"
                                           FontSize="18" FontWeight="Bold"/>
                                <Button Content="🖨️ Print" Command="{Binding PrintInvoiceCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Right" Padding="12,8"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Customer" Foreground="#888888" FontSize="11"/>
                                    <TextBlock Text="{Binding CurrentInvoice.CustomerName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CurrentInvoice.CustomerMobile}" FontSize="12" Foreground="#888888"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Date" Foreground="#888888" FontSize="11"/>
                                    <TextBlock Text="{Binding CurrentInvoice.InvoiceDate, StringFormat='{}{0:dd MMM yyyy}'}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding CurrentInvoice.StatusName}" FontSize="12" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid ItemsSource="{Binding CurrentInvoice.Items}" IsReadOnly="True" MaxHeight="200" Margin="0,0,0,10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Item" Binding="{Binding ItemDescription}" Width="*"/>
                                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="40"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmount, StringFormat='₹{0:N0}'}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Background="#F8F9FA" CornerRadius="6" Padding="12">
                                <StackPanel>
                                    <Grid Margin="0,3"><TextBlock Text="Total:"/><TextBlock Text="{Binding CurrentInvoice.TotalAmount, StringFormat='₹{0:N2}'}" HorizontalAlignment="Right" FontWeight="Bold"/></Grid>
                                    <Grid Margin="0,3"><TextBlock Text="Paid:"/><TextBlock Text="{Binding CurrentInvoice.PaidAmount, StringFormat='₹{0:N2}'}" HorizontalAlignment="Right" Foreground="#4CAF50"/></Grid>
                                    <Grid Margin="0,3"><TextBlock Text="Balance:" FontWeight="Bold"/><TextBlock Text="{Binding CurrentInvoice.PendingAmount, StringFormat='₹{0:N2}'}" HorizontalAlignment="Right" Foreground="#E94560" FontWeight="Bold"/></Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="Select an invoice to view details"
                                   Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Center"
                                   Margin="0,50,0,0"
                                   Visibility="{Binding CurrentInvoice, Converter={StaticResource NullToInverseVisibilityConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>

