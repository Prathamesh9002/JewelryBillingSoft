<Window x:Class="JewelryBillingSoft.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:JewelryBillingSoft.UI.Views"
        xmlns:vm="clr-namespace:JewelryBillingSoft.UI.ViewModels"
        mc:Ignorable="d"
        Title="Jewelry Billing Soft"
        Height="780" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BillingViewModel}">
            <views:BillingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerViewModel}">
            <views:CustomerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
            <views:InventoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="5" Opacity="0.3"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="{Binding IsSidebarExpanded, Converter={StaticResource SidebarWidthConverter}}"/>
                <!-- Main Content -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="0"
                    Background="{StaticResource DarkBrush}" Height="48"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- App Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,0">
                        <TextBlock Text="💎" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Jewelry Billing Soft" Foreground="#FFD700"
                                   FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Page Title -->
                    <TextBlock Grid.Column="1" Text="{Binding CurrentView}"
                               Foreground="#AAAAAA" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
                        <TextBlock Text="{Binding CurrentUserName}" Foreground="#AAAAAA"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Button Content="—" Click="MinimizeButton_Click"
                                Width="32" Height="32" Background="Transparent"
                                Foreground="#AAAAAA" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                        <Button Content="□" Click="MaximizeButton_Click"
                                Width="32" Height="32" Background="Transparent"
                                Foreground="#AAAAAA" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                        <Button Content="✕" Click="CloseButton_Click"
                                Width="32" Height="32" Background="Transparent"
                                Foreground="#AAAAAA" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sidebar -->
            <Border Grid.Column="0" Grid.Row="1" Background="{StaticResource SidebarBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,10">
                        <!-- Toggle sidebar -->
                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding ToggleSidebarCommand}"
                                Margin="5,0,5,10">
                            <TextBlock Text="☰" FontSize="18" Foreground="#AAAAAA"/>
                        </Button>

                        <!-- Nav Items -->
                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding NavigateToDashboardCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="18" Width="28"/>
                                <TextBlock Text="Dashboard" FontSize="14" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding NavigateToBillingCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧾" FontSize="18" Width="28"/>
                                <TextBlock Text="Billing" FontSize="14" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding NavigateToCustomersCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="18" Width="28"/>
                                <TextBlock Text="Customers" FontSize="14" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding NavigateToInventoryCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦" FontSize="18" Width="28"/>
                                <TextBlock Text="Inventory" FontSize="14" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding NavigateToReportsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📈" FontSize="18" Width="28"/>
                                <TextBlock Text="Reports" FontSize="14" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Separator Background="#FFFFFF20" Margin="10,10"/>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding NavigateToSettingsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️" FontSize="18" Width="28"/>
                                <TextBlock Text="Settings" FontSize="14" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SidebarButtonStyle}"
                                Command="{Binding LogoutCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" FontSize="18" Width="28"/>
                                <TextBlock Text="Logout" FontSize="14" VerticalAlignment="Center"
                                           Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Main Content -->
            <Border Grid.Column="1" Grid.Row="1" Background="{StaticResource BackgroundBrush}">
                <ContentControl Content="{Binding CurrentViewModel}" Margin="0"/>
            </Border>
        </Grid>
    </Border>
</Window>

